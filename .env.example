# Sarawak Tourism & Culture Synth - Environment Variables

# Google Gemini API Key (Required)
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Data Directory (Optional - defaults to "data")
# Path to folder containing PDF documents
DATA_DIR=data

# ChromaDB Directory (Optional - defaults to ".chroma")
# Path to store the vector database
CHROMA_DIR=.chroma

# Embedding Model (Optional - defaults to "all-MiniLM-L6-v2")
# Sentence-transformers model name for embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunk Size (Optional - defaults to 1000)
# Size of text chunks for document splitting
CHUNK_SIZE=1000

# Chunk Overlap (Optional - defaults to 200)
# Overlap between text chunks
CHUNK_OVERLAP=200
